{
  "expo": {
    "name": "Nexus Kingdom",
    "slug": "nexus-kingdom",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#030712",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#030712"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nexuskingdom.milla",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Milla needs your microphone for voice chat",
        "NSFaceIDUsageDescription": "Biometric authentication for Nexus Kingdom"
      }
    },
    "android": {
      "package": "com.nexuskingdom.milla",
      "permissions": ["RECORD_AUDIO", "USE_BIOMETRIC", "USE_FINGERPRINT", "VIBRATE"],
      "adaptiveIcon": {
        "backgroundColor": "#030712"
      }
    },
    "plugins": [
      ["expo-notifications", { "color": "#f59e0b" }]
    ]
  }
}

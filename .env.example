# ============================================================
# Nexus Kingdom / MEA OS — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ------------------------------------------------------------
# AI PROVIDERS — Primary model (xAI Grok is default)
# ------------------------------------------------------------
XAI_API_KEY=                        # xAI API key — get at console.x.ai
XAI_MODEL=grok-4-latest             # Model ID (grok-4-latest recommended)

# Gemini (fallback / optional)
GEMINI_API_KEY=                     # Google AI Studio key

# Ollama Cloud (optional — for remote/hosted Ollama)
OLLAMA_CLOUD_HOST=                  # e.g. https://api.ollama.com
OLLAMA_CLOUD_KEY=                   # Ollama cloud API key
OLLAMA_CLOUD_MODEL=llama3.3:70b     # Model to use on cloud

# OpenRouter (optional)
OPENROUTER_API_KEY=

# Venice AI (optional)
VENICE_API_KEY=

# ElevenLabs TTS (optional — edge-tts is used by default, no key needed)
ELEVENLABS_API_KEY=

# Hugging Face (optional)
HF_TOKEN=

# ------------------------------------------------------------
# LOCAL OLLAMA
# ------------------------------------------------------------
OLLAMA_HOST=localhost:11434         # Local Ollama host:port
OLLAMA_MODEL=milla-rayne            # Primary local model name
MILLA_BASE_MODEL=qwen2.5-coder:7b  # Base model for Modelfile

# ------------------------------------------------------------
# GOOGLE SERVICES (Gmail, Calendar, Drive, Nest)
# ------------------------------------------------------------
# OAuth credentials live in core_os/config/credentials.json
# After first run: visit http://localhost:8000/api/oauth/login
NEST_PROJECT_ID=                    # Google Nest SDM project ID

# ------------------------------------------------------------
# TELEGRAM BOT
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=                 # @BotFather token
TELEGRAM_CHAT_ID=                   # Your chat ID (use @userinfobot)

# ------------------------------------------------------------
# GITHUB
# ------------------------------------------------------------
GITHUB_PERSONAL_ACCESS_TOKEN=      # For skill installation from private repos

# ------------------------------------------------------------
# NETWORK / TAILSCALE
# ------------------------------------------------------------
NEXUS_TAILSCALE_IP=100.89.122.112  # This machine's Tailscale IP
NEXUS_SERVER_URL=http://100.89.122.112:8000
MY_PHONE_TAILSCALE_IP=             # Your phone's Tailscale IP
MY_PHONE_IP=                       # Your phone's local IP (optional)
MY_PHONE_PORT=5555                 # ADB port (optional)

# ------------------------------------------------------------
# MILLA BEHAVIOR FLAGS
# ------------------------------------------------------------
MILLA_YOLO_MODE=1                  # 1 = Milla acts autonomously without confirmation prompts
MILLA_ENABLE_FLASK=1               # 1 = enable legacy Flask routes (if used)
